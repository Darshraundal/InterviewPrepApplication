<?xml version="1.0" encoding="utf-8"?>
<!--
  This file is used by Azure App Service / IIS via the ASP.NET Core Module (ANCM).
  stdoutLogEnabled: set to true temporarily to diagnose startup errors (500.30 etc.)
  Log files appear at logs/stdout_*.log in the app root (D:\home\site\wwwroot\logs\).

  NOTE: processPath is intentionally left as the dotnet publish default.
  The SDK transforms this file at publish time:
    - Self-contained  →  processPath=".\InterviewPrepPortal.exe"
    - Framework-dep.  →  processPath="dotnet" arguments=".\InterviewPrepPortal.dll"
  Do NOT hardcode processPath here; let the SDK manage it.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="%LAUNCHER_PATH%"
                  arguments="%LAUNCHER_ARGS%"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
<!-- Do not remove this comment. It is here to work around a known issue with web.config transformation by the .NET SDK publish pipeline. -->
