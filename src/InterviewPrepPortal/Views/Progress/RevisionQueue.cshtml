@model IReadOnlyList<InterviewPrepPortal.ViewModels.Category.QuestionWithUserData>
@using InterviewPrepPortal.Models
@{
    ViewData["Title"] = "Revision Queue";
}

<div class="page-header">
    <h2>🔄 Revision Queue</h2>
    <p class="subtitle">Questions you've flagged for revision. Review them regularly.</p>
</div>

@if (Model.Any())
{
    <div class="question-list">
        @for (int i = 0; i < Model.Count; i++)
        {
            var item = Model[i];
            var q = item.Question;
            var status = item.Progress?.Status ?? ProgressStatus.NotStarted;
            <div class="q-card status-revision" style="border-left-color:var(--ip-danger);" data-question-id="@q.Id" data-source="category">
                <div class="q-header">
                    <span class="q-num">@(i+1).</span>
                    <span class="q-title">@q.QuestionText</span>
                    <div class="q-badges">
                        <span class="badge-freq @q.Frequency.Replace("-","")">@q.Frequency.Replace("-"," ")</span>
                        <span class="badge-diff @q.Difficulty">@q.Difficulty</span>
                    </div>
                    <a asp-controller="Question" asp-action="Detail" asp-route-id="@q.Id"
                       style="font-size:.78rem;color:var(--ip-accent-2);white-space:nowrap;">Open →</a>
                    <span class="q-chevron">▼</span>
                </div>
                <div class="q-body">
                    <div class="answer-box">@Html.Raw(q.Answer)</div>
                    <div class="status-controls">
                        <button class="status-btn @(status == ProgressStatus.Mastered ? "active-mastered" : "")" data-status="2">✓ Mastered</button>
                        <button class="toggle-btn revision-toggle active-revision">🔄 Revision Needed</button>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-icon">🎉</div>
        <h3>Revision queue is empty!</h3>
        <p>Flag questions with 🔄 to add them here.</p>
    </div>
}
