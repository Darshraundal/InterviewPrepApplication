@model InterviewPrepPortal.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">
        <h2>🎯 Welcome back</h2>
        <p class="auth-sub">Sign in to your Interview Prep Portal</p>

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" type="email" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
                <input asp-for="RememberMe" type="checkbox" style="accent-color:var(--ip-accent);width:14px;height:14px;" />
                <label asp-for="RememberMe" style="font-size:.82rem;color:var(--ip-text-2);margin:0;">Remember me</label>
            </div>

            <button type="submit" class="btn-primary-full">Sign In</button>
        </form>

        <div class="auth-footer">
            Don't have an account?
            <a asp-action="Register" asp-route-returnUrl="@ViewData["ReturnUrl"]">Create one</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
